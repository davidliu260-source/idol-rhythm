# Supabase — copy this file to .env.local and fill in your project values.
# Never commit .env.local to version control.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets — MUST NOT use NEXT_PUBLIC_ prefix (would leak to browser).
# Required by /api/cron/sync-candidates (J5b).
#   CRON_SECRET: Bearer token Vercel Cron sends in Authorization header.
#   SUPABASE_SERVICE_ROLE_KEY: bypasses RLS; only used in the CRON_SECRET-gated
#     cron route to insert into event_candidates. Never imported into client.
CRON_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — required by /api/admin/ai/parse-candidate (J3).
ANTHROPIC_API_KEY=

# YouTube Data API v3 — required by the youtube_official_channel crawler
# (P2-A1). Server-side only, no NEXT_PUBLIC_ prefix. Create the key in Google
# Cloud Console, enable YouTube Data API v3, and (recommended) restrict by
# IP or referrer. Default free quota: 10,000 units / day; we use ~2 units per
# active channel per cron run (playlistItems.list + videos.list).
YOUTUBE_API_KEY=
